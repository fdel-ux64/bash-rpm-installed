#!/bin/bash

# rpm-installed — List installed RPM packages by install date with caching

# ---- Global helpers — defined once, outside main function ----

RPM_SUMMARY_THRESHOLD=75

__rpm_installed_help() {
    cat <<-'EOF'
	rpm-installed — list installed RPM packages by install date

	USAGE:
	  rpm-installed [OPTION]
	  rpm-installed days N             # last N days (rolling window)
	  rpm-installed since DATE [until DATE]
	  rpm-installed count [OPTION] (including 'since … until …')
	  rpm-installed --refresh  # rebuild cache

	OPTIONS:
	  today        Packages installed today
	  yesterday    Packages installed yesterday
	  days N       Packages installed in the last N days (today included)
	  last-week    Packages installed in the last 7 days (excludes today)
	  this-month   Packages installed this calendar month
	  last-month   Packages installed in the previous calendar month

	ALIASES:
	  td  → today
	  yd  → yesterday
	  lw  → last-week
	  tm  → this-month
	  lm  → last-month

	COUNT / STATS:
	  rpm-installed count today
	  rpm-installed count days 5
	  rpm-installed count last-week
	  rpm-installed count per-day
	  rpm-installed count per-week
	  rpm-installed count since DATE [until DATE]
	EOF
}

__instlist_rpm() {
    rpm -qa --qf '%{INSTALLTIME} %{NAME}-%{VERSION}-%{RELEASE}.%{ARCH}\n'
}

__display_rpm_packages() {
    local cache_status="$1"
    local title="$2"
    shift 2
    local -a packages=("$@")
    local pkg_count=${#packages[@]}

    if [[ $pkg_count -eq 0 ]]; then
        echo
        echo "       📭 No packages installed: $title"
        echo "          Try: rpm-installed last-week  or  rpm-installed this-month"
        echo
        return
    fi

    # Build output into a temp file so we can decide whether to page it
    local tmpfile
    tmpfile=$(mktemp /tmp/rpm_installed.XXXXXX)

    # Build two parallel arrays: dates and names
    local -a dates=()
    local -a names=()
    local ts name day

    for pkg in "${packages[@]}"; do
        ts="${pkg%% *}"
        name="${pkg#* }"
        day=$(LC_ALL=en_US.UTF-8 date -d "@$ts" '+%a %Y-%m-%d' 2>/dev/null)
        [[ -z "$day" ]] && day="unknown"
        dates+=("$day")
        names+=("$name")
    done

    # Emit grouped output into tmpfile
    local current_date=""
    local total=${#names[@]}
    local i j run

    (
        printf "\n    📦 Installed packages — %s\n\n" "$title"

        for (( i = 0; i < total; i++ )); do
            day="${dates[$i]}"
            name="${names[$i]}"

            if [[ "$day" != "$current_date" ]]; then
                run=0
                for (( j = i; j < total && dates[j] == "$day"; j++ )); do
                    (( run++ ))
                done
                current_date="$day"
                printf " 📆 %s  \e[2m(%d package%s)\e[0m\n" \
                    "$day" "$run" "$( (( run == 1 )) && echo "" || echo "s" )"
            fi

            printf "    %s\n" "$name"
        done

        printf "\n ────────────────────────────────────\n"
        # Title always repeated in footer so it's visible without scrolling up
        printf " 🔢 Total: %d package%s — %s\n" \
            "$pkg_count" "$( (( pkg_count == 1 )) && echo "" || echo "s" )" "$title"
        printf " 💾 Cache: %s\n" "$cache_status"
        printf "\n"
    ) > "$tmpfile"

    # Auto-page when output would overflow the terminal; skip when piped
    local term_lines="${LINES:-24}"
    local file_lines
    file_lines=$(wc -l < "$tmpfile")
    if (( file_lines > term_lines )) && [ -t 1 ]; then
        cat "$tmpfile" | less -R
    else
        cat "$tmpfile"
    fi

    rm -f "$tmpfile"
}


rpm-installed() {
    local RPM_INSTALLED_CACHE_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/rpm_installed_cache"

    # ---- Distro check ----
    if ! command -v rpm &>/dev/null; then
        echo "❌ This function requires RPM package manager"
        echo "   Current system does not appear to be RPM-based"
        return 1
    fi

    local arg="${1:-}"
    [[ -n "$arg" ]] && arg=$(echo "$arg" | tr '[:upper:]' '[:lower:]')

    # ---- Help ----
    if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
        __rpm_installed_help
        return 0
    fi

    # ---- Refresh cache ----
    if [[ "$arg" == "--refresh" ]]; then
        rm -f "$RPM_INSTALLED_CACHE_FILE"
        echo "♻️  Cache cleared. Will rebuild on next call."
        return 0
    fi

    # ---- Build cache if missing ----
    if [[ ! -f "$RPM_INSTALLED_CACHE_FILE" ]]; then
        mkdir -p "$(dirname "$RPM_INSTALLED_CACHE_FILE")"
        local tmp_cache
        tmp_cache=$(mktemp "${RPM_INSTALLED_CACHE_FILE}.XXXXXX")
        __instlist_rpm > "$tmp_cache" && mv "$tmp_cache" "$RPM_INSTALLED_CACHE_FILE" || {
            rm -f "$tmp_cache"
            echo "❌ Failed to build cache" >&2
            return 1
        }
    fi

    # ---- Alias normalization ----
    case "$arg" in
        td) arg="today" ;;
        yd) arg="yesterday" ;;
        lw) arg="last-week" ;;
        tm) arg="this-month" ;;
        lm) arg="last-month" ;;
    esac

    # ---- count/stats mode: shift args ----
    local count_mode=0
    local arg2="${2:-}"
    [[ -n "$arg2" ]] && arg2=$(echo "$arg2" | tr '[:upper:]' '[:lower:]')

    if [[ "$arg" == "count" || "$arg" == "stats" ]]; then
        count_mode=1
        arg="$arg2"
        case "$arg" in
            td) arg="today" ;;
            yd) arg="yesterday" ;;
            lw) arg="last-week" ;;
            tm) arg="this-month" ;;
            lm) arg="last-month" ;;
        esac
    fi

    # ---- Time boundaries ----
    local today_start tomorrow_start yesterday_start
    local last_week_start this_month_start last_month_start
    today_start=$(LC_ALL=en_US.UTF-8      date -d 'today 00:00'                +%s)
    tomorrow_start=$(LC_ALL=en_US.UTF-8   date -d 'tomorrow 00:00'             +%s)
    yesterday_start=$(LC_ALL=en_US.UTF-8  date -d 'yesterday 00:00'            +%s)
    last_week_start=$(LC_ALL=en_US.UTF-8  date -d '7 days ago 00:00'           +%s)
    this_month_start=$(LC_ALL=en_US.UTF-8 date -d "$(date +%Y-%m-01)"          +%s)
    last_month_start=$(LC_ALL=en_US.UTF-8 date -d "$(date +%Y-%m-01) -1 month" +%s)

    # ---- Resolve s/e from $arg ----
    local s=0
    local e=""
    local n_days=0   # >0 when 'days N' was used; drives heading

    case "$arg" in
        today)
            s=$today_start;      e=$tomorrow_start ;;
        yesterday)
            s=$yesterday_start;  e=$today_start ;;
        last-week)
            s=$last_week_start;  e=$today_start ;;
        this-month)
            s=$this_month_start; e=$tomorrow_start ;;
        last-month)
            s=$last_month_start; e=$this_month_start ;;
        days)
            # Next positional arg shifts by 1 in count mode
            local raw_n_idx=$(( count_mode + 2 ))
            local raw_n="${!raw_n_idx}"
            if [[ -z "$raw_n" ]]; then
                echo "❌ 'days' requires a number  →  rpm-installed days 3" >&2
                return 1
            fi
            if ! [[ "$raw_n" =~ ^[1-9][0-9]*$ ]]; then
                echo "❌ 'days' expects a positive integer, got: '$raw_n'" >&2
                return 1
            fi
            n_days=$raw_n
            s=$(LC_ALL=en_US.UTF-8 date -d "$n_days days ago 00:00" +%s)
            e=$tomorrow_start ;;
        per-day)
            if [[ $count_mode -eq 1 ]]; then
                echo "❌ 'count per-day' is redundant — per-day already counts by day" >&2
                return 1
            fi
            awk '{count[strftime("%Y-%m-%d",$1)]++} END{for(d in count) printf "%s  %d\n", d, count[d]}' \
                "$RPM_INSTALLED_CACHE_FILE" | sort
            return ;;
        per-week)
            if [[ $count_mode -eq 1 ]]; then
                echo "❌ 'count per-week' is redundant — per-week already counts by week" >&2
                return 1
            fi
            awk '{count[strftime("%Y-W%V",$1)]++} END{for(w in count) printf "%s  %d\n", w, count[w]}' \
                "$RPM_INSTALLED_CACHE_FILE" | sort
            return ;;
        since|until)
            ;;          # handled by the for-loop below — do nothing here
        '')
            s=0 ;;
        *)
            echo "❌ Invalid option: '$arg'"
            echo
            __rpm_installed_help
            return 1 ;;
    esac

    # ---- since / until override ----
    local since_epoch="" until_epoch=""
    local freeform_date=0
    local i idx token
    for (( i = 1; i <= $#; i++ )); do
        token="${!i}"
        [[ -n "$token" ]] && token=$(echo "$token" | tr '[:upper:]' '[:lower:]')

        if [[ "$token" == "since" ]]; then
            (( idx = i + 1 ))
            if (( idx > $# )); then
                echo "❌ 'since' requires a date argument" >&2
                return 1
            fi
            since_epoch=$(LC_ALL=en_US.UTF-8 date -d "${!idx} 00:00" +%s 2>/dev/null)
            if [[ -z "$since_epoch" ]]; then
                echo "❌ Invalid date for 'since': ${!idx}" >&2
                echo "   Expected a format understood by 'date -d' (e.g. YYYY-MM-DD)"
                return 1
            fi
            s=$since_epoch
            freeform_date=1

        elif [[ "$token" == "until" ]]; then
            (( idx = i + 1 ))
            if (( idx > $# )); then
                echo "❌ 'until' requires a date argument" >&2
                return 1
            fi
            until_epoch=$(LC_ALL=en_US.UTF-8 date -d "${!idx} +1 day 00:00" +%s 2>/dev/null)
            if [[ -z "$until_epoch" ]]; then
                echo "❌ Invalid date for 'until': ${!idx}" >&2
                echo "   Expected a format understood by 'date -d' (e.g. YYYY-MM-DD)"
                return 1
            fi
            e=$until_epoch
            freeform_date=1
        fi
    done

    # ---- Execute ----
    if [[ $count_mode -eq 1 ]]; then
        awk -v s="$s" -v e="$e" '
            $1>=s && (e=="" || $1<e) {
                count[strftime("%Y-%m-%d",$1)]++
            }
            END { for (d in count) printf "%s  %d\n", d, count[d] }
        ' "$RPM_INSTALLED_CACHE_FILE" | sort
    else
        local heading="$arg"
        if (( n_days > 0 )); then
            heading="last $n_days days"
        elif [[ $freeform_date -eq 1 ]]; then
            heading="since $(LC_ALL=en_US.UTF-8 date -d "@$s" +%Y-%m-%d)"
            if [[ -n "$until_epoch" ]]; then
                local display_until
                display_until=$(LC_ALL=en_US.UTF-8 date -d "@$e -1 day" +%Y-%m-%d)
                heading="$heading until $display_until"
            fi
        fi

        local -a result=()
        while IFS= read -r line; do
            result+=("$line")
        done < <(awk -v s="$s" -v e="$e" '$1>=s && (e=="" || $1<e)' \
                     "$RPM_INSTALLED_CACHE_FILE" | sort -n)

        __display_rpm_packages "file cache" "$heading" "${result[@]}"
    fi
}

# If script is executed directly (not sourced), run the function
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    rpm-installed "$@"
fi
